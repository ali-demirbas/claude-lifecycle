{
  "id": "saas-trial-conversion-02",
  "version": "1.0.0",
  "constraints": { "max_discount_pct": 10, "allowed_channels": ["email", "in_app", "push"] },
  "name": "Trial Conversion (branched)",
  "pattern": "trial-conversion",
  "stage": "revenue",
  "priority": "P0",
  "data_tier": "T2",
  "dqs": 72,
  "depth_class": "branched",
  "objective": "Trial to paid within the trial clock, with an activation split",
  "trigger": { "type": "event", "value": "trial_start", "entry_conditions": ["no active subscription"], "reentry_policy": "once per trial" },
  "audience": { "include": "trial account admins", "exclude": ["suppressed accounts"], "estimated_volume": 40 },
  "exit": { "success_event": "subscription_start", "success_window_days": 21, "other_exits": ["unsubscribe"] },
  "steps": [
    { "index": 1, "wait": "PT1H", "channel": "email", "intent": "welcome + first value action", "branch_condition": null, "copy_ref": "step-1" },
    { "index": 2, "wait": "P2D", "channel": "in_app", "intent": "obstacle removal", "branch_condition": "no feature_used by day 3", "copy_ref": "step-2" },
    { "index": 3, "wait": "P2D", "channel": "email", "intent": "activation-split content", "branch_condition": "feature_used status", "copy_ref": "step-3" },
    { "index": 4, "wait": "P3D", "channel": "push", "intent": "expiry notice + last call", "branch_condition": null, "copy_ref": "step-4" }
  ],
  "flow": {
    "kind": "entry",
    "tag": "Giriş Kuralları",
    "title": "trial_start, aktif abonelik yok",
    "rows": [
      { "icon": "clock", "html": "<b>Tetikleyici:</b> trial_start; tüm adımlar trial penceresine sığar" },
      { "icon": "target", "html": "<b>Hedef kitle:</b> trial hesabının admin'i" }
    ],
    "children": [
      { "label": null, "node": {
        "kind": "message",
        "channel": "email",
        "tag": "Gün 0 · Email → Admin",
        "title": "welcome + first value action",
        "rows": [{ "icon": "mail", "html": "Tek CTA: <code class=\"variable\">{{first_name}}</code> için ilk değer anı" }],
        "children": [
          { "label": null, "node": {
            "kind": "decision",
            "tag": "Yol Ayrımı",
            "title": "3. günde feature_used var mı?",
            "rows": [{ "icon": "filter", "html": "Aktivasyon dallanması: aktive olana satın alma, sessize kurtarma" }],
            "extra": { "Veri notu": "Eşik pattern pratiğinden; canlıda öncü göstergeyle doğrulanır" },
            "children": [
              { "label": "Evet", "node": {
                "kind": "message",
                "channel": "email",
                "tag": "Gün 2 · Email → Admin",
                "title": "activation-split content",
                "rows": [{ "icon": "mail", "html": "Kullandığı feature üzerinden use-case genişletme" }],
                "children": [
                  { "label": null, "node": { "kind": "exit", "exit": "good", "title": "Dönüştü" } }
                ]
              } },
              { "label": "Hayır", "node": {
                "kind": "message",
                "channel": "in_app",
                "tag": "Gün 2 · In-app → Admin",
                "title": "obstacle removal",
                "rows": [{ "icon": "chat", "html": "'Nerede takıldın?' + destek fast-lane" }],
                "children": [
                  { "label": null, "node": {
                    "kind": "message",
                    "channel": "push",
                    "tag": "Bitiş -3g · Push → Admin",
                    "title": "expiry notice + last call",
                    "rows": [{ "icon": "bell", "html": "Net durum: tarih, fiyat, veriye ne olacağı" }],
                    "children": [
                      { "label": null, "node": { "kind": "exit", "exit": "bad", "title": "Süresi doldu" } }
                    ]
                  } }
                ]
              } }
            ]
          } }
        ]
      } }
    ]
  },
  "kpis": [
    { "name": "trial to paid", "type": "primary", "definition": "conversions vs entered", "target": null },
    { "name": "unsubscribe rate", "type": "guardrail", "definition": "per send", "target": "< 0.3%" }
  ]
}
